# Output directories — selective carve-out for committed audit artifacts.
# Anchored to repo root so source-layer dirs (src/screener/data/) are NOT
# ignored. Universe Parquet snapshots and per-ticker splits ledgers ARE
# committed (small, audit-relevant); per-ticker prices.parquet stays local.
# Phase 1 originally said `/data/`; Phase 2 (D-19 reconciled with D-06 per
# Amendment 2026-05-02) carves out two committed paths.
/data/*
!/data/universe/
!/data/universe/.gitkeep
!/data/ohlcv/
/data/ohlcv/**/prices.parquet
!/data/ohlcv/**/splits.parquet
!/data/ohlcv/**/.gitkeep
!/data/snapshots/
/data/snapshots/*.parquet
!/data/snapshots/.gitkeep
/reports/
/runs.jsonl

# Phase 6 — fundamentals + insider + pattern audit (gitignored per D-05).
# Literal blanket-ignore lines so the Wave 0 verifier finds the expected
# `^data/<dir>/$` patterns. Anchor each directory with a committed
# `.gitkeep` so the runtime dir exists even when contents are absent
# (mirrors the Phase 2 snapshots carve-out).
data/fundamentals/
data/insider/
data/pattern_audit/
!/data/fundamentals/
/data/fundamentals/*
!/data/fundamentals/.gitkeep
!/data/insider/
/data/insider/*
!/data/insider/.gitkeep
!/data/pattern_audit/
/data/pattern_audit/*
!/data/pattern_audit/.gitkeep

# IDE
.vscode/
.idea/
