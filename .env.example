# API keys for the v1 stack. Copy to `.env` and fill in.
# .env is gitignored; .env.example is the committed template.

# --- Phase 6+ (REQUIRED for `make fundamentals`) ---
# Finnhub free tier (60 req/min) — earnings calendar, profile, news.
# REQUIRED for Phase 6+. Sign up: https://finnhub.io/dashboard
FINNHUB_API_KEY=your_finnhub_key_here

# FRED API key — VIX, Treasury yields, ISM
# Request: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# SEC EDGAR requires User-Agent identity ("Name <email>"). REQUIRED for
# Phase 6+ or `cli.refresh-fundamentals` fails loud at startup
# (CAT-04 / Pitfall 3). Used by edgartools.set_identity() at CLI startup.
EDGAR_IDENTITY=Your Name <you@example.com>

# Universe selection (default: russell1000)
UNIVERSE=russell1000

# RS percentile lookback in trading days (default: 252 = 1 year)
RS_LOOKBACK_DAYS=252

# Risk per trade as fraction of account equity (default: 0.0075 = 0.75%)
RISK_PCT_PER_TRADE=0.0075

# Account equity for sizing math (default: 100_000)
ACCOUNT_EQUITY=100000

# Phase 2 — data-layer paths and policy (D-20)
OHLCV_CACHE_DIR=data/ohlcv
UNIVERSE_CACHE_DIR=data/universe
OHLCV_BACKFILL_START=2005-01-01
UNIVERSE_HEALTH_THRESHOLD=0.95
STOOQ_BREAKER_PROBE_N=50
STOOQ_BREAKER_THRESHOLD=0.80
OHLCV_FETCH_SLEEP_MIN_S=0.5
OHLCV_FETCH_SLEEP_MAX_S=1.5

# Phase 3 — macro + RS snapshot paths and regime thresholds (D-12)
MACRO_CACHE_DIR=data/macro
RS_SNAPSHOT_DIR=data/rs_snapshots
MACRO_BACKFILL_START=2005-01-01
REGIME_BREADTH_THRESHOLD=0.60
REGIME_DIST_DAYS_PRESSURE=5
REGIME_DIST_DAYS_CORRECTION=9
REGIME_VIX_CORRECTION=30.0
REGIME_VIX_CONFIRMED=20.0

# Phase 6 — fundamentals + insider + pattern audit paths (D-05/D-08/D-09).
# Optional path overrides; defaults shown below.
# FUNDAMENTALS_CACHE_DIR=data/fundamentals
# INSIDER_CACHE_PATH=data/insider/form4.sqlite
# PATTERN_AUDIT_DIR=data/pattern_audit
